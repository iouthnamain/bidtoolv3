# Copy this file to deploy/onprem/.env.customer and edit it for one customer.

# Published BidTool application image. Release bundles set this to the matching
# GitHub Container Registry tag.
BIDTOOL_APP_IMAGE=ghcr.io/iouthnamain/bidtoolv3:latest

# Host ports exposed by the bundled Caddy reverse proxy.
BIDTOOL_HTTP_PORT=13000
BIDTOOL_HTTPS_PORT=13443

# Caddy site address inside the container. Keep ":80" for LAN HTTP behind the
# host port above. Use "bidtool.customer.example.com" when DNS points to this
# server and host ports 80/443 are mapped.
BIDTOOL_SITE_ADDRESS=:80

# Public URL users type in their browser or desktop client.
APP_BASE_URL=http://localhost:13000

POSTGRES_DB=bidtoolv3
POSTGRES_USER=bidtool
POSTGRES_PASSWORD=change-me-generate-with-install-script

BIDWINNER_BASE_URL=https://bidwinner.info
BIDWINNER_TIMEOUT_MS=15000

ENABLE_DEMO_SEED=false
BIDTOOL_RUN_MIGRATIONS=true
BIDTOOL_MIGRATION_ATTEMPTS=30
BIDTOOL_MIGRATION_RETRY_MS=2000

BIDTOOL_BACKUP_DIR=./backups/onprem
