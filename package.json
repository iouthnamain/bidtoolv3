{
  "name": "bidtoolv3",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "description": "Single-user local dashboard for tender discovery, material catalog import, and BidWinner workflows.",
  "type": "module",
  "engines": {
    "node": ">=20",
    "bun": ">=1.3"
  },
  "packageManager": "bun@1.3.11",
  "keywords": [
    "bidwinner",
    "tender",
    "procurement",
    "vietnam",
    "nextjs",
    "trpc",
    "drizzle",
    "excel",
    "internal-tool"
  ],
  "scripts": {
    "build": "bun run ./scripts/build-next.ts",
    "check": "eslint . && tsc --noEmit",
    "dev": "next dev --turbo",
    "dev:install": "bun run ./scripts/local-dev.ts install",
    "dev:kill": "bun run ./scripts/kill-local-dev.ts",
    "dev:run": "bun run ./scripts/local-dev.ts run",
    "dev:update": "bun run ./scripts/local-dev.ts update",
    "db:clear": "bun run ./scripts/db-clear.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run ./scripts/db-migrate.ts",
    "db:seed": "bun run ./scripts/db-seed.ts",
    "demo:samples": "bun run ./scripts/generate-demo-material-samples.ts && bunx vitest run tests/demo-material-samples.test.ts",
    "db:studio": "drizzle-kit studio",
    "db:wipe": "bun run ./scripts/db-wipe.ts",
    "auth:backfill": "bun run ./scripts/auth-backfill.ts",
    "desktop:build": "bun run ./scripts/build-next.ts --dist .next-electron && bun run ./scripts/prepare-electron-standalone.ts --dist .next-electron && electron-builder --projectDir .electron-build/app --config ../../electron-builder.config.cjs --publish never",
    "desktop:dev": "bun run ./scripts/desktop-dev.ts",
    "desktop:pack": "bun run ./scripts/build-next.ts --dist .next-electron && bun run ./scripts/prepare-electron-standalone.ts --dist .next-electron && electron-builder --projectDir .electron-build/app --config ../../electron-builder.config.cjs --dir --publish never",
    "desktop:prepare": "bun run ./scripts/prepare-electron-standalone.ts",
    "desktop:start": "electron .",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "onprem:backup": "sh ./scripts/onprem-backup.sh",
    "onprem:bundle": "sh ./scripts/onprem-package-release.sh",
    "onprem:install": "sh ./scripts/onprem-install.sh",
    "onprem:restore": "sh ./scripts/onprem-restore.sh",
    "onprem:update": "sh ./scripts/onprem-update.sh",
    "preview": "bun run build && bun run start",
    "release": "bun run ./scripts/release-cli.ts",
    "release:major": "bun run ./scripts/release-cli.ts major --yes",
    "release:manifest": "bun run ./scripts/generate-release-manifest.ts",
    "release:minor": "bun run ./scripts/release-cli.ts minor --yes",
    "release:pins": "bun run ./scripts/update-release-pins.ts",
    "release:patch": "bun run ./scripts/release-cli.ts patch --yes",
    "release:status": "bun run ./scripts/release-cli.ts status",
    "setup": "bun run dev:install",
    "start": "node scripts/start-next-standalone.mjs",
    "start:mock-update-server": "bun run ./scripts/mock-update-server.ts",
    "start:dev": "bun run dev:run",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "update": "bun run dev:update"
  },
  "dependencies": {
    "@sparticuz/chromium-min": "147.0.2",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.69.0",
    "@tanstack/react-table": "^8.17.3",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@vercel/analytics": "^2.0.1",
    "better-auth": "^1.6.19",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.6.2",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "next": "15.5.18",
    "papaparse": "^5.5.3",
    "playwright": "1.59.1",
    "playwright-core": "1.59.1",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "superjson": "^2.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20.14.10",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/ui": "^4.1.6",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.23.0",
    "eslint-config-next": "15.5.18",
    "postcss": "^8.5.14",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "esbuild": "0.25.12",
    "postcss": "8.5.14"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  }
}
