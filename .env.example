# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Example:
# SERVERVAR="foo"
# NEXT_PUBLIC_CLIENTVAR="bar"

# Optional override when Playwright has no build for your Linux distro yet
# (e.g. Ubuntu 26.04+). The app auto-falls back to ubuntu24.04-x64, or set:
# PLAYWRIGHT_HOST_PLATFORM_OVERRIDE="ubuntu24.04-x64"

NODE_ENV="development"
POSTGRES_HOST_PORT="55432"
DATABASE_URL="postgresql://bidtool:bidtool@localhost:55432/bidtoolv3"
APP_BASE_URL="http://localhost:3000"
BIDWINNER_BASE_URL="https://bidwinner.info"
BIDWINNER_TIMEOUT_MS="15000"
ENABLE_DEMO_SEED="false"
SCRAPE_MAX_CONCURRENT_JOBS="2"
SCRAPE_MAX_CONCURRENT_PAGES="2"
IMPORT_MAX_CONCURRENT_JOBS="2"
SCRAPE_JOB_TTL_DAYS="7"

# Optional for Electron desktop clients that should connect to an on-prem server
# instead of starting the bundled local server.
BIDTOOL_SERVER_URL=""

# Optional OpenRouter integration (overrides database-stored key when set)
OPENROUTER_API_KEY=""
OPENROUTER_DEFAULT_MODEL="openai/gpt-4o-mini"

# Excel product research jobs
EXCEL_RESEARCH_MAX_CONCURRENT_JOBS="1"
EXCEL_RESEARCH_BATCH_SIZE="10"
EXCEL_RESEARCH_JOB_TTL_DAYS="7"
# Optional SearXNG instance for web evidence gathering (material enrich + excel research)
# Local dev: docker compose up searxng -d  →  http://localhost:8888
SEARXNG_BASE_URL="http://localhost:8888"
SEARXNG_HOST_PORT="8888"
# Optional override for on-disk excel research artifacts (default: data/excel-research)
BIDTOOL_EXCEL_RESEARCH_DIR=""

# --- Authentication & RBAC (Better Auth) ---
# Master switch. While "false" the app behaves exactly as before: no login gate,
# no per-user/tenant scoping. Flip to "true" to enable auth (run the migration
# and `bun run auth:backfill` first — see docs/temp/auth-and-rbac.md).
AUTH_ENABLED="false"
# Required when AUTH_ENABLED=true. Min 32 chars. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Base URL for auth callbacks (defaults to APP_BASE_URL when unset)
BETTER_AUTH_URL="http://localhost:3000"
# One-time token gating the /setup page that creates the first admin (web/on-prem)
AUTH_BOOTSTRAP_TOKEN=""
# Desktop: auto-create + sign in a local admin on first run when no users exist
AUTH_DESKTOP_AUTO_ADMIN="true"
